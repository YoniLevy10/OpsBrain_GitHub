{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --prefix ./opsbrain",
  "buildCommand": "npm run build --prefix ./opsbrain",
  "outputDirectory": "opsbrain/dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
