# OpsBrain (primary Supabase project)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Bamakor — separate Supabase project (optional; property module)
VITE_BAMAKOR_URL=https://your-bamakor-project.supabase.co
VITE_BAMAKOR_KEY=your_bamakor_anon_key

# AI (optional)
VITE_OPENAI_KEY=

# v0 by Vercel (optional) — Platform API / v0-sdk
# Never use VITE_* for this: it would ship the key to every browser bundle.
# Set on the server only (Vercel env, Supabase Edge Function secrets, etc.).
# https://v0.dev/docs/api/platform/guides/environment-variables
V0_API_KEY=

# Optional: public site URL on Vercel (webhooks / links)
VITE_APP_URL=https://opsbrain-xi.vercel.app/
VITE_WEBHOOK_BASE_URL=https://opsbrain-xi.vercel.app/
